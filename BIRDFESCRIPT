local function disableCollision(partA, partB)
	local ncc = Instance.new("NoCollisionConstraint")
	ncc.Part0 = partA
	ncc.Part1 = partB
	ncc.Parent = partA
end

local BirdLoopConnection : RBXScriptConnection
local BirdLoopConnection1 : RBXScriptConnection
local flapCoroutine = nil

local poop : BasePart
local Center : BasePart

local function Move(part : BasePart,cframe : CFrame)
	part.AssemblyLinearVelocity = Vector3.new(0,30,0)
	part.CFrame = cframe
end

local function reanimate()
	if BirdLoopConnection then BirdLoopConnection:Disconnect() end
	if BirdLoopConnection1 then BirdLoopConnection1:Disconnect() end
	
	if poop then
		poop:Destroy()
	end
	
	if Center then
		Center:Destroy()
	end

	---ASSIGN---
	local char = lp.Character
	
	if not char then
		StarterGui:SetCore("SendNotification",{
			Title = "Bird FE",
			Text = "No character found",
			Duration = 2
		})
		
		return
	end
	
	local Head = char:FindFirstChild("Head")
	
	if not Head or not Head:IsA("BasePart") then
		StarterGui:SetCore("SendNotification",{
			Title = "Bird FE",
			Text = "No head found",
			Duration = 2
		})

		return
	end
	
	local moving = false
	local lastcam = (workspace.CurrentCamera :: Camera).CFrame.Rotation

	local bob_offset = 0
	local bob_change = 0.02
	local pooped = false

	local wing_angle = 0
	local wa_change = 5 --Wing Flap Speed
	
	do
		local Humanoid = char:FindFirstChildOfClass("Humanoid")
		
		if Humanoid then
			Humanoid.Health = 0
		end
	end

	Center = Instance.new("Part")
	
	Center.Anchored = true
	Center.Transparency = 1
	
	local current_position = Head.Position + Vector3.new(0,1,0);

	(workspace.CurrentCamera :: Camera).CameraSubject = Center

	local speed = 0

	poop = Instance.new("Part",workspace)
	poop.Size = Vector3.new(1,1,1)
	poop.Position = Head.Position
	poop.Anchored = true
	poop.Transparency = 1
	
	local HeadCFrame = CFrame.identity
	local BodyCFrame = CFrame.identity
	local RWingCFrame = CFrame.identity
	local LWingCFrame = CFrame.identity
	
	BirdLoopConnection = RunService.Heartbeat:Connect(function()
		local camera = (workspace.CurrentCamera :: Camera)
		
		camera.CameraSubject = Center
		
		char = lp.Character
		
		if not char then return end
		
		local vbody = char:FindFirstChild("MediHood")
		local vhead = char:FindFirstChild("Normal Beak")
		local vlwing = char:FindFirstChild("LongRedHair")
		local vrwing = char:FindFirstChild("LongHairBeanie")
		local vpoop = char:FindFirstChild("Poop Head")
		
		if not vbody or not vhead or not vlwing or not vrwing or not vpoop then return end
		
		vbody = vbody:FindFirstChild("Handle")
		vhead = vhead:FindFirstChild("Handle")
		vlwing = vlwing:FindFirstChild("Handle")
		vrwing = vrwing:FindFirstChild("Handle")
		vpoop = vpoop:FindFirstChild("Handle")
		
		if
			not vbody or not vhead or not vlwing or not vrwing or not vpoop or
			not vbody:IsA("BasePart") or not vhead:IsA("BasePart") or not vlwing:IsA("BasePart") or
			not vrwing:IsA("BasePart") or not vpoop:IsA("BasePart")
		then return end
		
		do
			local Humanoid = char:FindFirstChildOfClass("Humanoid")
			
			if Humanoid then
				Humanoid.Health = 0
			end
		end
		
		lp.SimulationRadius = 10000
		
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then
			current_position += camera.CFrame.RightVector * speed
			moving=true
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then
			current_position += camera.CFrame.RightVector * -speed
			moving=true
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then
			current_position += camera.CFrame.LookVector * speed
			moving=true
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then
			current_position += camera.CFrame.LookVector * -speed
			moving=true
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.E) then
			current_position += camera.CFrame.UpVector * speed
			moving=true
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.Q) then
			current_position += camera.CFrame.UpVector * -speed
			moving=true
		end
		if not (UserInputService:IsKeyDown(Enum.KeyCode.D) or UserInputService:IsKeyDown(Enum.KeyCode.A) or UserInputService:IsKeyDown(Enum.KeyCode.W) or UserInputService:IsKeyDown(Enum.KeyCode.S) or UserInputService:IsKeyDown(Enum.KeyCode.Q) or UserInputService:IsKeyDown(Enum.KeyCode.E)) then
			moving=false
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then do
				speed = 2
			end else
			speed = 0.70
		end
		
		Center.Position = current_position
		
		if bob_offset > 0 then
			bob_change = -bob_change
		end
		if bob_offset < -1.5 then
			bob_change = -bob_change
		end
		if moving == false then
			bob_offset += bob_change
		end
		if wing_angle >= 30 then
			wa_change = -wa_change
		end
		if wing_angle <= -30 then
			wa_change = -wa_change
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
			wing_angle += wa_change*2
		else
			wing_angle += wa_change
		end
		if moving == true then
			lastcam = camera.CFrame.Rotation
		end
		if pooped == false then
			poop.CFrame = (Center.CFrame + Vector3.new(0,bob_offset,0))
			poop.Anchored = true
		end
		
		BodyCFrame = (Center.CFrame + Vector3.new(0,bob_offset,0)) * lastcam
		HeadCFrame = BodyCFrame * CFrame.new(0,0.075,0) + BodyCFrame.LookVector * 1.25
		LWingCFrame = BodyCFrame * CFrame.Angles(0,0,math.rad(wing_angle)) * CFrame.new(-2,0,0)
		RWingCFrame = BodyCFrame * CFrame.Angles(0,0,math.rad(-wing_angle)) * CFrame.new(2,0,0)
		
		Move(vpoop, poop.CFrame)
		Move(vbody, BodyCFrame)
		Move(vhead, HeadCFrame)
		Move(vrwing, (RWingCFrame- RWingCFrame.RightVector * .3) * CFrame.Angles(math.rad(90),0,math.rad(90)))
		Move(vlwing, (LWingCFrame - LWingCFrame.RightVector * -.3) * CFrame.Angles(math.rad(-90),0,math.rad(-90)))

		if UserInputService:IsKeyDown(Enum.KeyCode.X) and not pooped then
			pooped = true
			poop.Anchored = false
			fart:Play()
			task.delay(5, function()
				pooped = false
			end)
		end
	end)
	
	BirdLoopConnection1 = lp.CharacterAdded:Connect(function()
		local OldCameraCFrame = (workspace.CurrentCamera :: Camera).CFrame
		
		RunService.PreRender:Once(function()
			(workspace.CurrentCamera :: Camera).CFrame = OldCameraCFrame
		end)
	end)
end

